# Configuración para Desarrollo Local
# IMPORTANTE: Las contraseñas NUNCA deben estar en este archivo en producción
# Usar AWS Secrets Manager, Systems Manager Parameter Store, o variables de entorno en el shell

# ⚠️ VARIABLES REQUERIDAS (sin valores por defecto por seguridad)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=agrocomparador

# Variables opcionales con valores por defecto
DB_PORT=3306
DB_NAME=agrocomparador
PORT=8080

